generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum InvoiceStatus {
  DRAFT
  EMITIDA
  CANCELADA
}

enum CobrancaStatus {
  PENDENTE
  PAGA
  EXPIRADA
  CANCELADA
}

enum DASStatus {
  PENDENTE
  PAGO
  VENCIDO
}

enum ClientType {
  PF
  PJ
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  stripeCustomerId         String?   @unique
  stripePriceId            String?
  stripeSubscriptionId     String?   @unique
  stripeCurrentPeriodEnd   DateTime?
  trialEndsAt              DateTime?
  plan                     Plan      @default(FREE)

  accounts Account[]
  sessions Session[]
  invoices Invoice[]
  clients  Client[]
  das      DAS[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id       String     @id @default(cuid())
  userId   String
  nome     String
  cpfCnpj  String
  email    String?
  endereco String?
  tipo     ClientType

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id         String        @id @default(cuid())
  userId     String
  clientId   String
  descricao  String
  valor      Float
  status     InvoiceStatus @default(DRAFT)
  nfeKey     String?
  emitidaAt  DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id])
  cobranca  Cobranca?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cobranca {
  id        String         @id @default(cuid())
  invoiceId String         @unique
  pixQrCode String?
  valor     Float
  pagoAt    DateTime?
  status    CobrancaStatus @default(PENDENTE)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DAS {
  id          String    @id @default(cuid())
  userId      String
  competencia String
  valor       Float
  pagoAt      DateTime?
  status      DASStatus @default(PENDENTE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, competencia])
}
